
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an individual user (employee) of the VENDIXPRO system.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "manager", "seller"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "role", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "categoryId": { "type": "string" },
        "imageUrl": { "type": "string", "description": "URL of the product image" },
        "isVariablePrice": { "type": "boolean", "description": "If true, POS will prompt for price" }
      },
      "required": ["id", "name", "price", "stockQuantity"]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "currentBalance": { "type": "number" }
      },
      "required": ["id", "name", "currentBalance"]
    },
    "Sale": {
      "title": "Sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "userId": { "type": "string" },
        "customerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "totalAmount", "paymentMethod", "userId"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "concept": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["id", "concept", "amount", "date"]
    },
    "CashSession": {
      "title": "CashSession",
      "type": "object",
      "description": "Represents a daily cash shift or session.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "openingBalance": { "type": "number" },
        "expectedClosingBalance": { "type": "number" },
        "actualClosingBalance": { "type": "number" },
        "difference": { "type": "number" },
        "openedAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "status", "openingBalance", "openedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "User profiles for employees."
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": "#/backend/entities/Category",
      "description": "Product categories for specific user."
    },
    "/users/{userId}/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Inventory products for specific user."
    },
    "/users/{userId}/customers/{customerId}": {
      "schema": "#/backend/entities/Customer",
      "description": "Customer list for specific user."
    },
    "/users/{userId}/sales/{saleId}": {
      "schema": "#/backend/entities/Sale",
      "description": "Sales records for specific user."
    },
    "/users/{userId}/expenses/{expenseId}": {
      "schema": "#/backend/entities/Expense",
      "description": "Expenses for specific user."
    },
    "/users/{userId}/cash_sessions/{sessionId}": {
      "schema": "#/backend/entities/CashSession",
      "description": "Cash shifts and closures."
    }
  }
}
