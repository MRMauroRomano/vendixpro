rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VENDIXPRO SECURITY RULES (PROTOTYPE VERSION)
     * 
     * Para este prototipo, permitimos lectura y escritura a cualquier usuario
     * que haya iniciado sesión (incluyendo usuarios anónimos).
     */

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}